{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axeno",
  "version": "0.1.1",
  "identifier": "chat.axeno.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Axeno",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 500,
        "decorations": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 http://127.0.0.1:1420",
        "img-src": "'self' asset: http://asset.localhost data:",
        "style-src": "'self'",
        "script-src": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "appimage",
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFEM0RBNzc2N0U5M0I4NTIKUldSU3VKTitkcWM5SFJxVVZCTm4xRjZVbGI5TkRWRzBPSEpGdFg0TTJiSjB2VERzczRhcmdkcjYK",
      "endpoints": [
        "https://github.com/axenochat/axeno-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
